{
	"editor.formatOnSave": true,
	"i18n-ally.localesPaths": ["src/assets/i18n"],
	"i18n-ally.keystyle": "nested",
	"i18n-ally.sourceLanguage": "zh-CN",
	"i18n-ally.displayLanguage": "zh-CN",
	"i18n-ally.indent": 1,
	"i18n-ally.tabStyle": "tab",
	"swift.path": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin",
	"swift.SDK": "/Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk",
	"swift.swiftEnvironmentVariables": {
		"DEVELOPER_DIR": "/Applications/Xcode.app/Contents/Developer"
	},
	"swift.sourcekit-lsp.serverArguments": [
		"--default-workspace-type",
		"buildServer",
		"-Xswiftc",
		"-parse-as-library"
	],
	"files.eol": "\r\n",
	"[json]": {
		"editor.insertSpaces": false,
		"editor.tabSize": 4
	},
	"[swift]": {
		"editor.defaultFormatter": null,
		"editor.formatOnSave": false
	},
	"files.exclude": {
		"**/.DS_Store": true,
		"apple-app/Build": true,
		"apple-app/DerivedData": true,
		"apple-app/DerivedData-iOS": true,
		"apple-app/YouTubeTweakExtension/dist": true
	},
	"search.exclude": {
		"apple-app/Build": true,
		"apple-app/DerivedData": true,
		"apple-app/DerivedData-iOS": true,
		"apple-app/YouTubeTweakExtension/dist": true,
		".output/safari-mv2/chunks": true,
		".output/safari-mv2-dev/chunks": true
	},
	"files.associations": {
		"manifest.json": "jsonc"
	}
}
