{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build macOS Debug",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "apple:build:mac:debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Run macOS App",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "apple:run:mac"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build macOS Release",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "apple:build:mac:release"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build iOS Debug No Signing",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "apple:build:ios:debug:no-sign"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Open Xcode Project",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "apple:open:xcode"
      ],
      "problemMatcher": []
    },
    {
      "label": "Generate Xcode Build Server Config",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "apple:build-server"
      ],
      "problemMatcher": []
    },
    {
      "label": "Clean Local DerivedData",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "apple:clean"
      ],
      "problemMatcher": []
    }
  ]
}
