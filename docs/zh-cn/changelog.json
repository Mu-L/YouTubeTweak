{
	"schemaVersion": 1,
	"sources": {
		"zh-CN": "CHANGELOG.md"
	},
	"releases": [
		{
			"version": "1.1.8",
			"date": "2026-07-03",
			"changes": {
				"zh-CN": {
					"updated": [
						{
							"scope": "设置界面",
							"text": "优化配置导入导出和检查更新结果的提示显示。"
						},
						{
							"scope": "播放器控制",
							"text": "优化倍速、旋转、镜像等自定义控制操作时的播放器控制栏显示。"
						}
					],
					"added": [
						{
							"scope": "倍速控制",
							"text": "新增倍速滑块，支持拖拽连续调速、鼠标滚轮调速和自定义滚轮步长。"
						},
						{
							"scope": "画面缩放",
							"text": "新增鼠标滚轮缩放视频画面，放大后可拖拽移动画面。"
						},
						{
							"scope": "播放器功能按钮",
							"text": "新增视频截图按钮，支持保存当前视频画面为 PNG 图片。"
						},
						{
							"scope": "播放器按钮",
							"text": "新增播放器按钮显示模式，支持自动、隐藏和强制启用。"
						},
						{
							"scope": "自定义 CSS",
							"text": "新增自定义 CSS 编辑器，支持向 YouTube 注入自定义样式。"
						},
						{
							"scope": "配置管理",
							"text": "新增导出/导入记忆数据的选项，支持随设置迁移分频道倍速、字幕等记忆。"
						}
					]
				}
			}
		},
		{
			"version": "1.1.7",
			"date": "2026-06-12",
			"changes": {
				"zh-CN": {
					"updated": [
						{
							"scope": "广告屏蔽",
							"text": "新增 YouTube 购物推荐栏相关屏蔽规则。"
						},
						{
							"scope": "禁用暂停",
							"text": "改进“视频已暂停，继续播放？”弹窗识别，避免误关其他弹窗。"
						},
						{
							"scope": "记忆存储",
							"text": "将 500ms 内的重复写入合并处理，减少不必要的存储更新。"
						},
						{
							"scope": "迷你播放器",
							"text": "简化弹出窗口中迷你播放器的尺寸显示。"
						},
						{
							"scope": "i18n",
							"text": "更新新版播放器与回退设置相关翻译。"
						},
						{
							"scope": "依赖",
							"text": "更新 WXT/构建工具，移除旧版浏览器全局变量兼容代码。"
						}
					],
					"added": [
						{
							"scope": "迷你播放器",
							"text": "新增滚动迷你播放器，支持设置尺寸、位置、屏幕边距与触发距离。"
						},
						{
							"scope": "音量增强器",
							"text": "新增真实音量增强功能，支持播放器内控制与自定义增强级别。"
						},
						{
							"scope": "评论翻译",
							"text": "新增多行评论逐行显示译文的选项。"
						},
						{
							"scope": "播放器界面",
							"text": "新增隐藏 YouTube 迷你播放器按钮的选项。"
						},
						{
							"scope": "回退",
							"text": "新增回到旧版 YouTube 播放界面布局的选项。"
						}
					],
					"fixed": [
						{
							"scope": "迷你播放器",
							"text": "改进进入/退出迷你播放器模式时的层级与布局恢复。"
						},
						{
							"scope": "回退",
							"text": "修复开启旧版播放界面布局后，非 16:9 视频被塞进 16:9 外壳里显示的问题。"
						}
					]
				}
			}
		},
		{
			"version": "1.1.5",
			"date": "2026-04-11",
			"changes": {
				"zh-CN": {
					"updated": [
						{
							"scope": "广告屏蔽",
							"text": "添加了两个新的屏蔽规则。"
						}
					],
					"added": [
						{
							"scope": "禁用暂停",
							"text": "防止播放一段时间后自动暂停（“视频已暂停。继续观看？”提示）。"
						}
					],
					"fixed": [
						{
							"scope": "评论翻译",
							"text": "修复了切换评论排序后翻译内容未更新的问题。"
						}
					]
				}
			}
		},
