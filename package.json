{
	"name": "youtube-tweak",
	"private": true,
	"version": "1.2.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"dev:safari": "LOCAL_DEV_HTTPS=1 wxt -b safari",
		"cert:local-dev": "bash build/local-dev-cert.sh",
		"build": "vue-tsc --noEmit && wxt build && tsx build/chrome-crx3.ts",
		"build:edge": "vue-tsc --noEmit && wxt zip -b edge",
		"build:firefox": "vue-tsc --noEmit && wxt zip -b firefox",
		"build:safari": "vue-tsc --noEmit && wxt zip -b safari",
		"build:all": "npm i && vue-tsc --noEmit && wxt build && tsx build/chrome-crx3.ts && wxt zip -b edge && wxt zip -b firefox",
		"compile": "vue-tsc --noEmit",
		"dev:ios": "tsx build/apple.ts dev:ios",
		"dev:ios:watch": "tsx build/apple.ts dev:ios:watch",
		"dev:mac": "tsx build/apple.ts dev:mac",
		"dev:mac:watch": "tsx build/apple.ts dev:mac:watch",
		"build:ios": "tsx build/apple.ts build:ios",
		"build:mac": "tsx build/apple.ts build:mac",
		"build:ios:debug": "tsx build/apple.ts build:ios:debug",
		"build:mac:debug": "tsx build/apple.ts build:mac:debug",
		"apple:icons": "tsx build/apple.ts icons",
		"apple:open:xcode": "open apple-app/YouTubeTweakExtension.xcodeproj",
		"apple:build-server": "tsx build/apple.ts build-server",
		"apple:clean": "rm -rf apple-app/Build apple-app/DerivedData apple-app/DerivedData-iOS",
		"postinstall": "wxt prepare"
	},
	"devDependencies": {
		"@wxt-dev/auto-icons": "^1.1.0",
		"@wxt-dev/module-vue": "^1.0.2",
		"crx3": "^1.1.3",
		"dotenv": "^17.2.3",
		"prettier": "^3.6.2",
		"sass": "^1.91.0",
		"tsx": "^4.20.6",
		"typescript": "5.9.2",
		"vite-plugin-vue-devtools": "^8.0.1",
		"vue-tsc": "^3.0.6",
		"wxt": "^0.20.26"
	},
	"dependencies": {
		"codejar": "^4.3.0",
		"pinia": "^3.0.3",
		"prismjs": "^1.30.0",
		"vue": "^3.5",
		"vue-i18n": "^11.1.11"
	},
	"overrides": {
		"esbuild": "0.28.1",
		"shell-quote": "1.8.4",
		"tmp": "0.2.7",
		"uuid": "11.1.1"
	}
}
